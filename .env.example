# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=erp_db

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-byte-random-hex
JWT_REFRESH_SECRET=replace-with-64-byte-random-hex

# ─── AI (OpenRouter) ─────────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai → Keys → Create Key
# The API is OpenAI-compatible — no OpenAI account or billing needed.
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Any model slug from https://openrouter.ai/models — free models marked :free
OPENROUTER_MODEL=qwen/qwen3-coder:free

# ─── File Uploads (Cloudinary) ───────────────────────────────────────────────
# From https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

# ─── Frontend ────────────────────────────────────────────────────────────────
# URL the browser uses to reach the backend.
# In Docker full-stack mode this is set automatically via docker-compose build args.
NEXT_PUBLIC_API_URL=http://localhost:5000
